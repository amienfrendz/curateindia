# GitHub Models — required for /api/search, /api/availability, /api/reviews
# Create a fine-grained PAT at https://github.com/settings/personal-access-tokens
# Scope needed: "Models" → Read-only ("models:read")
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — override the default model
# Defaults to openai/gpt-4o-mini. Other options: openai/gpt-4o, openai/gpt-4.1-mini, etc.
# GITHUB_MODELS_MODEL=openai/gpt-4o-mini
